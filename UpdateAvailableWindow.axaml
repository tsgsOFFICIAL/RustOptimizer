<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iface="using:RustOptimizer.Interface"
        xmlns:controls="using:RustOptimizer.Controls"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="520"
        x:Class="RustOptimizer.UpdateAvailableWindow"
        x:DataType="iface:ILocalizationService"
        Title="{Binding [UpdateAvailableTitle]}"
        Icon="/Assets/App/logo.ico"
        Width="480" Height="520"
        MinWidth="420" MinHeight="360"
        Background="{DynamicResource BgColor}"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <controls:TitleBar Grid.Row="0"
                            Title="{Binding [UpdateAvailableTitle]}"
                            Author="tsgsOFFICIAL"
                            ShowMaximizeButton="False">
            <controls:TitleBar.Icon>
                <Image Source="/Assets/App/logo.ico"/>
            </controls:TitleBar.Icon>
        </controls:TitleBar>

        <StackPanel Grid.Row="1" Margin="24,20,24,8" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding [UpdateAvailableMessage]}"
                           FontSize="20"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="VersionText"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentColor}"/>
            </StackPanel>
            <TextBlock x:Name="ChangelogHeader"
                       Text="{Binding [ChangelogTitle]}"
                       FontSize="15"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <ContentControl Grid.Row="2" x:Name="ChangelogHost" Margin="24,0,24,16"/>

        <Border Grid.Row="3"
                Padding="16"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <TextBlock x:Name="StatusText"
                           Classes="muted"
                           IsVisible="False"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button x:Name="LaterButton"
                        Content="{Binding [Later]}"
                        Click="OnLaterClick"/>
                <Button x:Name="UpdateButton"
                        Content="{Binding [UpdateNow]}"
                        Classes="accent"
                        Click="OnUpdateNowClick"/>
            </StackPanel>
        </Border>

    </Grid>

</Window>
