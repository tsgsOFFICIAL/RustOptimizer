<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iface="using:RustOptimizer.Interface"
        xmlns:controls="using:RustOptimizer.Controls"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="220"
        x:Class="RustOptimizer.UpdateAvailableWindow"
        x:DataType="iface:ILocalizationService"
        Title="{Binding [UpdateAvailableTitle]}"
        Icon="/Assets/App/logo.ico"
        Width="420" Height="220"
        MinWidth="380" MinHeight="200"
        CanResize="False"
        Background="{DynamicResource BgColor}"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto">

        <controls:TitleBar Grid.Row="0"
                            Title="{Binding [UpdateAvailableTitle]}"
                            Author="tsgsOFFICIAL"
                            ShowMaximizeButton="False">
            <controls:TitleBar.Icon>
                <Image Source="/Assets/App/logo.ico"/>
            </controls:TitleBar.Icon>
        </controls:TitleBar>

        <StackPanel Grid.Row="1" Margin="24" Spacing="8" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="{Binding [UpdateAvailableMessage]}"/>
                <TextBlock x:Name="VersionText" FontWeight="Bold"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" Classes="muted" IsVisible="False"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="16"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <Button x:Name="ChangelogButton"
                        Grid.Column="0"
                        Content="{Binding [ViewChangelog]}"
                        Click="OnViewChangelogClick"/>
                <Button x:Name="LaterButton"
                        Grid.Column="2"
                        Content="{Binding [Later]}"
                        Margin="0,0,8,0"
                        Click="OnLaterClick"/>
                <Button x:Name="UpdateButton"
                        Grid.Column="3"
                        Content="{Binding [UpdateNow]}"
                        Classes="accent"
                        Click="OnUpdateNowClick"/>
            </Grid>
        </Border>

    </Grid>

</Window>
