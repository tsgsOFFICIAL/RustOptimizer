<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RustOptimizer.ViewModels"
        xmlns:views="using:RustOptimizer.Views"
        xmlns:controls="using:RustOptimizer.Controls"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="520"
        x:Class="RustOptimizer.Windows.UpdateAvailableWindow"
        x:DataType="vm:UpdateAvailableViewModel"
        Title="{Binding Localization[UpdateAvailableTitle]}"
        Icon="/Assets/App/logo.ico"
        Width="480" Height="520"
        MinWidth="420" MinHeight="360"
        Background="{DynamicResource BgColor}"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto">

        <controls:TitleBar Grid.Row="0"
                            Localization="{Binding Localization}"
                            Title="{Binding Localization[UpdateAvailableTitle]}"
                            Author="tsgsOFFICIAL"
                            ShowMaximizeButton="False">
            <controls:TitleBar.Icon>
                <Image Source="/Assets/App/logo.ico"/>
            </controls:TitleBar.Icon>
        </controls:TitleBar>

        <views:UpdateAvailableView Grid.Row="1"/>

        <Border Grid.Row="2"
                Padding="16"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <TextBlock Text="{Binding StatusText}"
                           IsVisible="{Binding IsStatusVisible}"
                           Classes="muted"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button Content="{Binding Localization[Later]}"
                        Command="{Binding LaterCommand}"/>
                <Button Content="{Binding Localization[UpdateNow]}"
                        Classes="accentButton"
                        Command="{Binding UpdateNowCommand}"/>
            </StackPanel>
        </Border>

    </Grid>

</Window>