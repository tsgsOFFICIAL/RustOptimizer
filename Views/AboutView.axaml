<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:vm="using:RustOptimizer.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="RustOptimizer.Views.AboutView"
             x:DataType="vm:AboutViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="24">

            <TextBlock Text="{Binding Localization[AboutTitle]}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>

            <Border Classes="card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Image Source="/Assets/App/logo.ico" Width="48" Height="48"/>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Localization[AppTitle]}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding Localization[Version]}" Classes="muted" FontSize="12"/>
                                <TextBlock Text="{Binding VersionText}" Classes="muted" FontSize="12"/>
                                <TextBlock Text="·" Classes="muted" FontSize="12"/>
                                <TextBlock Text="{Binding Localization[By]}" Classes="muted" FontSize="12"/>
                                <TextBlock Text="tsgsOFFICIAL" Classes="muted" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding Localization[AppTagline]}" Classes="muted" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{Binding Localization[ViewChangelog]}" Command="{Binding ViewChangelogCommand}"/>
                        <Button Content="{Binding Localization[CheckForUpdates]}" Command="{Binding CheckForUpdatesCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding UpdateStatusText}" IsVisible="{Binding IsUpdateStatusVisible}" Classes="muted" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Application information: the details worth quoting in a bug report. -->
            <Border Classes="card">
                <StackPanel Spacing="0">
                    <StackPanel Spacing="0" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Localization[AboutInformationTitle]}" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>
                        <TextBlock Text="{Binding Localization[AboutInformationSubtitle]}" Classes="muted" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="140,*" Margin="0,14,0,0">
                        <TextBlock Grid.Column="0" Text="{Binding Localization[Version]}" Classes="muted" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="{Binding VersionText}" FontSize="12" Foreground="{DynamicResource TextColor}"/>
                    </Grid>
                    <Grid ColumnDefinitions="140,*" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Text="{Binding Localization[AboutBuildLabel]}" Classes="muted" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="{Binding BuildText}" FontSize="12" Foreground="{DynamicResource TextColor}"/>
                    </Grid>
                    <Grid ColumnDefinitions="140,*" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Text="{Binding Localization[OsLabel]}" Classes="muted" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="{Binding OsText}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextColor}"/>
                    </Grid>
                    <Grid ColumnDefinitions="140,*" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Text="{Binding Localization[AboutLicenseLabel]}" Classes="muted" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="{Binding LicenseText}" FontSize="12" Foreground="{DynamicResource TextColor}"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
