<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:vm="using:RustOptimizer.ViewModels"
             xmlns:converters="using:RustOptimizer.Converters"
             xmlns:avconverters="using:Avalonia.Data.Converters"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
             x:Class="RustOptimizer.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <Grid ColumnDefinitions="*,300">

        <ScrollViewer Grid.Column="0">
            <StackPanel Margin="24" Spacing="20">

                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Localization[DashboardTitle]}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>
                    <TextBlock Text="{Binding Localization[DashboardSubtitle]}" Classes="muted"/>
                </StackPanel>

                <!-- Hero -->
                <Border Classes="card" Padding="24">
                    <StackPanel Spacing="16" MaxWidth="440">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Localization[HeroTitle]}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>
                            <TextBlock Text=" " FontSize="24"/>
                            <TextBlock Text="{Binding Localization[HeroTitleAccent]}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Classes="muted" FontSize="13">
                            <Run Text="{Binding Localization[HeroDescription]}"/>
                            <Run Text="{Binding Localization[HeroDescriptionAccent]}" Foreground="{StaticResource AccentColor}" FontWeight="Bold"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <Button Classes="accentButton outOfOrder" Command="{Binding RunSmartOptimizationCommand}"
                                    ToolTip.Tip="{Binding Localization[ComingSoon]}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <iconPacks:PackIconPhosphorIcons Kind="RocketLaunch" Width="16" Height="16"/>
                                    <TextBlock Text="{Binding Localization[RunSmartOptimization]}" FontWeight="Bold"/>
                                    <iconPacks:PackIconPhosphorIcons Kind="Barricade" Width="14" Height="14"/>
                                </StackPanel>
                            </Button>
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[LastScan]}" Classes="muted" FontSize="12"/>
                                <TextBlock Text="{Binding Localization[LastScanNever]}" Classes="muted" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Optimization Overview -->
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Localization[OptimizationOverviewTitle]}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>
                    <Grid ColumnDefinitions="*,*,*,*">

                        <Border Grid.Column="0" Classes="card outOfOrder" Margin="0,0,6,0" ToolTip.Tip="{Binding Localization[ComingSoon]}">
                            <StackPanel Spacing="10">
                                <iconPacks:PackIconPhosphorIcons Kind="Gauge" Width="24" Height="24" Foreground="{StaticResource AccentColor}"/>
                                <StackPanel Spacing="0">
                                    <TextBlock Text="{Binding Localization[PerformanceLabel]}" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource TextColor}"/>
                                    <TextBlock Text="{Binding Localization[StatusNotOptimized]}" FontSize="12" Foreground="{StaticResource AccentColor}"/>
                                </StackPanel>
                                <TextBlock Text="0 / 23 settings" Classes="muted" FontSize="11"/>
                                <ProgressBar Classes="thinBar" Minimum="0" Maximum="23" Value="0" Foreground="{StaticResource AccentColor}"/>
                            </StackPanel>
                        </Border>

                        <Button Grid.Column="1" Classes="card" Padding="16" Margin="6,0,6,0" Command="{Binding ViewSystemDetailsCommand}">
                            <StackPanel Spacing="10">
                                <iconPacks:PackIconPhosphorIcons Kind="ShieldCheck" Width="24" Height="24"
                                                                  Foreground="{Binding SystemScore.Status, Converter={x:Static converters:OptimizationStatusColorConverter.Instance}}"/>
                                <StackPanel Spacing="0">
                                    <TextBlock Text="{Binding Localization[SystemLabel]}" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource TextColor}"/>
                                    <TextBlock Text="{Binding Localization[StatusGood]}" FontSize="12" Foreground="{StaticResource SuccessColor}"
                                               IsVisible="{Binding SystemScore.Status, Converter={x:Static avconverters:ObjectConverters.Equal}, ConverterParameter={x:Static vm:OptimizationStatus.Optimized}}"/>
                                    <TextBlock Text="{Binding Localization[StatusPartiallyOptimized]}" FontSize="12" Foreground="{StaticResource AccentColor}"
                                               IsVisible="{Binding SystemScore.Status, Converter={x:Static avconverters:ObjectConverters.Equal}, ConverterParameter={x:Static vm:OptimizationStatus.PartiallyOptimized}}"/>
                                    <TextBlock Text="{Binding Localization[StatusNotOptimized]}" FontSize="12" Foreground="{StaticResource DangerColor}"
                                               IsVisible="{Binding SystemScore.Status, Converter={x:Static avconverters:ObjectConverters.Equal}, ConverterParameter={x:Static vm:OptimizationStatus.NotOptimized}}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SystemScore.SettingsText}" Classes="muted" FontSize="11"/>
                                <ProgressBar Classes="thinBar" Minimum="0" Maximum="{Binding SystemScore.Total}" Value="{Binding SystemScore.Optimized}"
                                             Foreground="{Binding SystemScore.Status, Converter={x:Static converters:OptimizationStatusColorConverter.Instance}}"/>
                                <TextBlock Text="{Binding SystemIssuesSummaryText}" Classes="muted" FontSize="11" TextWrapping="Wrap"
                                           IsVisible="{Binding SystemIssuesSummaryText, Converter={x:Static avconverters:StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" Classes="card" Padding="16" Margin="6,0,6,0" Command="{Binding ViewNetworkDetailsCommand}">
                            <StackPanel Spacing="10">
                                <iconPacks:PackIconPhosphorIcons Kind="WifiHigh" Width="24" Height="24"
                                                                  Foreground="{Binding NetworkScore.Status, Converter={x:Static converters:OptimizationStatusColorConverter.Instance}}"/>
                                <StackPanel Spacing="0">
                                    <TextBlock Text="{Binding Localization[NetworkLabel]}" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource TextColor}"/>
                                    <TextBlock Text="{Binding Localization[StatusGood]}" FontSize="12" Foreground="{StaticResource SuccessColor}"
                                               IsVisible="{Binding NetworkScore.Status, Converter={x:Static avconverters:ObjectConverters.Equal}, ConverterParameter={x:Static vm:OptimizationStatus.Optimized}}"/>
                                    <TextBlock Text="{Binding Localization[StatusPartiallyOptimized]}" FontSize="12" Foreground="{StaticResource AccentColor}"
                                               IsVisible="{Binding NetworkScore.Status, Converter={x:Static avconverters:ObjectConverters.Equal}, ConverterParameter={x:Static vm:OptimizationStatus.PartiallyOptimized}}"/>
                                    <TextBlock Text="{Binding Localization[StatusNotOptimized]}" FontSize="12" Foreground="{StaticResource DangerColor}"
                                               IsVisible="{Binding NetworkScore.Status, Converter={x:Static avconverters:ObjectConverters.Equal}, ConverterParameter={x:Static vm:OptimizationStatus.NotOptimized}}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding NetworkScore.SettingsText}" Classes="muted" FontSize="11"/>
                                <ProgressBar Classes="thinBar" Minimum="0" Maximum="{Binding NetworkScore.Total}" Value="{Binding NetworkScore.Optimized}"
                                             Foreground="{Binding NetworkScore.Status, Converter={x:Static converters:OptimizationStatusColorConverter.Instance}}"/>
                                <TextBlock Text="{Binding NetworkIssuesSummaryText}" Classes="muted" FontSize="11" TextWrapping="Wrap"
                                           IsVisible="{Binding NetworkIssuesSummaryText, Converter={x:Static avconverters:StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </Button>

                        <Border Grid.Column="3" Classes="card outOfOrder" Margin="6,0,0,0" ToolTip.Tip="{Binding Localization[ComingSoon]}">
                            <StackPanel Spacing="10">
                                <iconPacks:PackIconPhosphorIcons Kind="Monitor" Width="24" Height="24" Foreground="{StaticResource GraphicsColor}"/>
                                <StackPanel Spacing="0">
                                    <TextBlock Text="{Binding Localization[GraphicsLabel]}" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource TextColor}"/>
                                    <TextBlock Text="{Binding Localization[StatusNotOptimized]}" FontSize="12" Foreground="{StaticResource AccentColor}"/>
                                </StackPanel>
                                <TextBlock Text="0 / 15 settings" Classes="muted" FontSize="11"/>
                                <ProgressBar Classes="thinBar" Minimum="0" Maximum="15" Value="0" Foreground="{StaticResource GraphicsColor}"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="0,24,24,24" Spacing="16">

                <!-- System Information -->
                <Border Classes="card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding Localization[SystemInformationTitle]}" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>

                        <Grid ColumnDefinitions="Auto,*">
                            <iconPacks:PackIconPhosphorIcons Grid.Column="0" Kind="Cpu" Width="20" Height="20" Margin="0,0,10,0" Foreground="{DynamicResource TextMutedColor}"/>
                            <StackPanel Grid.Column="1" Spacing="0">
                                <TextBlock Text="{Binding Localization[CpuLabel]}" Classes="muted" FontSize="11"/>
                                <TextBlock Text="{Binding CpuName}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextColor}"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <iconPacks:PackIconPhosphorIcons Grid.Column="0" Kind="GraphicsCard" Width="20" Height="20" Margin="0,0,10,0" Foreground="{DynamicResource TextMutedColor}"/>
                            <StackPanel Grid.Column="1" Spacing="0">
                                <TextBlock Text="{Binding Localization[GpuLabel]}" Classes="muted" FontSize="11"/>
                                <TextBlock Text="{Binding GpuName}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextColor}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <iconPacks:PackIconPhosphorIcons Kind="Memory" Width="20" Height="20" Foreground="{DynamicResource TextMutedColor}"/>
                            <StackPanel Spacing="0">
                                <TextBlock Text="{Binding Localization[RamLabel]}" Classes="muted" FontSize="11"/>
                                <TextBlock Text="{Binding RamText}" FontSize="12" Foreground="{DynamicResource TextColor}"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid ColumnDefinitions="Auto,*">
                            <iconPacks:PackIconPhosphorIcons Grid.Column="0" Kind="Monitor" Width="20" Height="20" Margin="0,0,10,0" Foreground="{DynamicResource TextMutedColor}"/>
                            <StackPanel Grid.Column="1" Spacing="0">
                                <TextBlock Text="{Binding Localization[OsLabel]}" Classes="muted" FontSize="11"/>
                                <TextBlock Text="{Binding OsDescription}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextColor}"/>
                            </StackPanel>
                        </Grid>

                        <Button Classes="listRow" Command="{Binding ViewSystemDetailsCommand}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Localization[MoreDetails]}" FontSize="12" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                <iconPacks:PackIconPhosphorIcons Grid.Column="1" Kind="CaretRight" Width="16" Height="16" Foreground="{DynamicResource TextMutedColor}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <Border Classes="card">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Localization[QuickActionsTitle]}" FontWeight="Bold" Foreground="{DynamicResource TextColor}" Margin="0,0,0,6"/>

                        <Button Classes="listRow" Command="{Binding VerifyRustFilesCommand}" IsEnabled="{Binding CanVerifyRustFiles}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <iconPacks:PackIconPhosphorIcons Grid.Column="0" Kind="ShieldCheck" Width="18" Height="18" Foreground="{DynamicResource TextMutedColor}" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Localization[VerifyGameFiles]}" FontSize="12" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                <iconPacks:PackIconPhosphorIcons Grid.Column="2" Kind="CaretRight" Width="16" Height="16" Foreground="{DynamicResource TextMutedColor}"/>
                            </Grid>
                        </Button>

                        <Button Classes="listRow outOfOrder" ToolTip.Tip="{Binding Localization[ComingSoon]}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <iconPacks:PackIconPhosphorIcons Grid.Column="0" Kind="Trash" Width="18" Height="18" Foreground="{DynamicResource TextMutedColor}" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Localization[ClearCache]}" FontSize="12" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                <iconPacks:PackIconPhosphorIcons Grid.Column="2" Kind="Barricade" Width="16" Height="16" Foreground="{DynamicResource TextMutedColor}"/>
                            </Grid>
                        </Button>

                        <Button Classes="listRow outOfOrder" ToolTip.Tip="{Binding Localization[ComingSoon]}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <iconPacks:PackIconPhosphorIcons Grid.Column="0" Kind="Power" Width="18" Height="18" Foreground="{DynamicResource TextMutedColor}" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Localization[OptimizeStartup]}" FontSize="12" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                <iconPacks:PackIconPhosphorIcons Grid.Column="2" Kind="Barricade" Width="16" Height="16" Foreground="{DynamicResource TextMutedColor}"/>
                            </Grid>
                        </Button>

                        <Button Classes="listRow outOfOrder" ToolTip.Tip="{Binding Localization[ComingSoon]}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <iconPacks:PackIconPhosphorIcons Grid.Column="0" Kind="DownloadSimple" Width="18" Height="18" Foreground="{DynamicResource TextMutedColor}" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Localization[UpdateDrivers]}" FontSize="12" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                <iconPacks:PackIconPhosphorIcons Grid.Column="2" Kind="Barricade" Width="16" Height="16" Foreground="{DynamicResource TextMutedColor}"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Preset Profiles -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Localization[PresetProfilesTitle]}" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>

                        <Button Classes="listRow" Tag="LowEndPc" Command="{Binding ApplyPresetCommand}" CommandParameter="{Binding $self.Tag}"
                                IsEnabled="{Binding CanApplyPreset}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Localization[ProfileLowEndPc]}" FontSize="12" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Localization[TagHighFps]}" Classes="muted" FontSize="12"/>
                            </Grid>
                        </Button>

                        <Button Classes="listRow" Tag="Competitive" Command="{Binding ApplyPresetCommand}" CommandParameter="{Binding $self.Tag}"
                                IsEnabled="{Binding CanApplyPreset}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Localization[ProfileCompetitive]}" FontSize="12" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Classes="pill">
                                    <TextBlock Text="{Binding Localization[TagRecommended]}"/>
                                </Border>
                            </Grid>
                        </Button>

                        <Button Classes="listRow" Tag="Cinematic" Command="{Binding ApplyPresetCommand}" CommandParameter="{Binding $self.Tag}"
                                IsEnabled="{Binding CanApplyPreset}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Localization[ProfileCinematic]}" FontSize="12" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Localization[TagBestQuality]}" Classes="muted" FontSize="12"/>
                            </Grid>
                        </Button>

                        <TextBlock Text="{Binding PresetStatusText}" TextWrapping="Wrap" Classes="muted" FontSize="11"/>

                        <Button Classes="listRow outOfOrder" ToolTip.Tip="{Binding Localization[ComingSoon]}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Localization[ManageProfiles]}" FontSize="12" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                <iconPacks:PackIconPhosphorIcons Grid.Column="1" Kind="Barricade" Width="16" Height="16" Foreground="{DynamicResource TextMutedColor}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>