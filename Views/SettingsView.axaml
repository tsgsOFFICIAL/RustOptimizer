<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:vm="using:RustOptimizer.ViewModels"
             xmlns:converters="using:RustOptimizer.Converters"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="RustOptimizer.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <!-- Section heading inside a card: bold title with a muted one-line explanation beneath. -->
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        </Style>
        <Style Selector="TextBlock.sectionSubtitle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedColor}"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- One setting: label on top, muted description underneath, control on the right. -->
        <Style Selector="TextBlock.settingLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        </Style>
        <Style Selector="TextBlock.settingDescription">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedColor}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style Selector="Border.settingRow">
            <Setter Property="Padding" Value="0,14"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="24">

            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization[SettingsTitle]}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>
                <TextBlock Text="{Binding Localization[SettingsPageSubtitle]}" Classes="muted"/>
            </StackPanel>

            <!-- Appearance -->
            <Border Classes="card">
                <StackPanel Spacing="0">
                    <StackPanel Spacing="0" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Localization[SettingsAppearanceTitle]}" Classes="sectionTitle"/>
                        <TextBlock Text="{Binding Localization[SettingsAppearanceSubtitle]}" Classes="sectionSubtitle"/>
                    </StackPanel>

                    <Border Classes="settingRow" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[ThemeLabel]}" Classes="settingLabel"/>
                                <TextBlock Text="{Binding Localization[ThemeDescription]}" Classes="settingDescription"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" VerticalAlignment="Center" MinWidth="160"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedTheme}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ThemeOption">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <iconPacks:PackIconPhosphorIcons Kind="{Binding Icon}" Width="16" Height="16" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Classes="settingRow">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[LanguageLabel]}" Classes="settingLabel"/>
                                <TextBlock Text="{Binding Localization[LanguageDescription]}" Classes="settingDescription"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" VerticalAlignment="Center" MinWidth="160"
                                      ItemsSource="{Binding LanguageOptions}"
                                      SelectedItem="{Binding SelectedLanguage}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LanguageOption">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <!-- Fixed height with proportional width keeps every flag the same
                                                 visual weight regardless of its aspect ratio. -->
                                            <Image Source="{Binding Flag}" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Application -->
            <Border Classes="card">
                <StackPanel Spacing="0">
                    <StackPanel Spacing="0" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Localization[SettingsApplicationTitle]}" Classes="sectionTitle"/>
                        <TextBlock Text="{Binding Localization[SettingsApplicationSubtitle]}" Classes="sectionSubtitle"/>
                    </StackPanel>

                    <Border Classes="settingRow" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[StartWithWindowsLabel]}" Classes="settingLabel"/>
                                <TextBlock Text="{Binding Localization[StartWithWindowsDescription]}" Classes="settingDescription"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding StartWithWindows}" OnContent="" OffContent=""/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Updates -->
            <Border Classes="card">
                <StackPanel Spacing="0">
                    <StackPanel Spacing="0" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Localization[SettingsUpdatesTitle]}" Classes="sectionTitle"/>
                        <TextBlock Text="{Binding Localization[SettingsUpdatesSubtitle]}" Classes="sectionSubtitle"/>
                    </StackPanel>

                    <Border Classes="settingRow" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[CheckForUpdatesOnStartupLabel]}" Classes="settingLabel"/>
                                <TextBlock Text="{Binding Localization[CheckForUpdatesOnStartupDescription]}" Classes="settingDescription"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding CheckForUpdatesOnStartup}" OnContent="" OffContent=""/>
                        </Grid>
                    </Border>

                    <!-- Disabled when the startup check is off: an automatic update can only follow a check. -->
                    <Border Classes="settingRow" IsEnabled="{Binding CanAutoUpdate}">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[AutoUpdateLabel]}" Classes="settingLabel"/>
                                <TextBlock Text="{Binding Localization[AutoUpdateDescription]}" Classes="settingDescription"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding AutoUpdate}" OnContent="" OffContent=""/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Units -->
            <Border Classes="card">
                <StackPanel Spacing="0">
                    <StackPanel Spacing="0" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Localization[SettingsUnitsTitle]}" Classes="sectionTitle"/>
                        <TextBlock Text="{Binding Localization[SettingsUnitsSubtitle]}" Classes="sectionSubtitle"/>
                    </StackPanel>

                    <Border Classes="settingRow" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[ThroughputUnitLabel]}" Classes="settingLabel"/>
                                <TextBlock Text="{Binding Localization[ThroughputUnitDescription]}" Classes="settingDescription"/>
                            </StackPanel>
                            <Border Grid.Column="1" Classes="segmentGroup" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <Button Classes="segment" Tag="Bytes" Content="{Binding Localization[ThroughputUnitBytes]}"
                                            Classes.active="{Binding ThroughputUnit, Converter={x:Static converters:EnumEqualsConverter.Instance}, ConverterParameter=Bytes}"
                                            Command="{Binding SetThroughputUnitCommand}" CommandParameter="{Binding $self.Tag}"/>
                                    <Button Classes="segment" Tag="Bits" Content="{Binding Localization[ThroughputUnitBits]}"
                                            Classes.active="{Binding ThroughputUnit, Converter={x:Static converters:EnumEqualsConverter.Instance}, ConverterParameter=Bits}"
                                            Command="{Binding SetThroughputUnitCommand}" CommandParameter="{Binding $self.Tag}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Data -->
            <Border Classes="card">
                <StackPanel Spacing="0">
                    <StackPanel Spacing="0" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Localization[SettingsDataTitle]}" Classes="sectionTitle"/>
                        <TextBlock Text="{Binding Localization[SettingsDataSubtitle]}" Classes="sectionSubtitle"/>
                    </StackPanel>

                    <Border Classes="settingRow" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[LogRetentionLabel]}" Classes="settingLabel"/>
                                <TextBlock Text="{Binding Localization[LogRetentionDescription]}" Classes="settingDescription"/>
                            </StackPanel>
                            <Border Grid.Column="1" Classes="segmentGroup" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <Button Classes="segment" Tag="7" Content="7"
                                            Classes.active="{Binding LogRetentionDays, Converter={x:Static converters:ValueEqualsConverter.Instance}, ConverterParameter=7}"
                                            Command="{Binding SetLogRetentionCommand}" CommandParameter="{Binding $self.Tag}"/>
                                    <Button Classes="segment" Tag="30" Content="30"
                                            Classes.active="{Binding LogRetentionDays, Converter={x:Static converters:ValueEqualsConverter.Instance}, ConverterParameter=30}"
                                            Command="{Binding SetLogRetentionCommand}" CommandParameter="{Binding $self.Tag}"/>
                                    <Button Classes="segment" Tag="90" Content="90"
                                            Classes.active="{Binding LogRetentionDays, Converter={x:Static converters:ValueEqualsConverter.Instance}, ConverterParameter=90}"
                                            Command="{Binding SetLogRetentionCommand}" CommandParameter="{Binding $self.Tag}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Classes="settingRow">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[VerboseLoggingLabel]}" Classes="settingLabel"/>
                                <TextBlock Text="{Binding Localization[VerboseLoggingDescription]}" Classes="settingDescription"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding VerboseLogging}" OnContent="" OffContent=""/>
                        </Grid>
                    </Border>

                    <Border Classes="settingRow">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Localization[LogFolderLabel]}" Classes="settingLabel"/>
                                <TextBlock Text="{Binding Localization[LogFolderDescription]}" Classes="settingDescription"/>
                            </StackPanel>
                            <Button Grid.Column="1" VerticalAlignment="Center"
                                    Content="{Binding Localization[OpenLogFolder]}" Command="{Binding OpenLogFolderCommand}"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
