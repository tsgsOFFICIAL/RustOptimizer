<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:vm="using:RustOptimizer.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RustOptimizer.Views.UtilitiesView"
             x:DataType="vm:UtilitiesViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.cardTitle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        </Style>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        </Style>
        <Style Selector="TextBlock.resourceUrl">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedColor}"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="24">

            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization[NavUtilities]}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>
                <TextBlock Text="{Binding Localization[UtilitiesPageSubtitle]}" Classes="muted"/>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="{Binding Localization[ExternalResourcesTitle]}" Classes="sectionTitle"/>

                <ItemsControl ItemsSource="{Binding Resources}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemSpacing="16" LineSpacing="16"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:UtilityResourceRow">
                            <Button Classes="card"
                                    Width="320"
                                    Command="{Binding $parent[ItemsControl].((vm:UtilitiesViewModel)DataContext).OpenResourceCommand}"
                                    CommandParameter="{Binding Url}">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <iconPacks:PackIconPhosphorIcons Kind="{Binding IconKind}" Width="20" Height="20" Foreground="{StaticResource AccentColor}"/>
                                        <TextBlock Text="{Binding Name}" Classes="cardTitle"/>
                                        <iconPacks:PackIconPhosphorIcons Kind="ArrowSquareOut" Width="14" Height="14" Foreground="{DynamicResource TextMutedColor}" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" Classes="muted" TextWrapping="Wrap" FontSize="12"/>
                                    <TextBlock Text="{Binding Url}" Classes="resourceUrl"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="6">
                <iconPacks:PackIconPhosphorIcons Kind="Info" Width="14" Height="14" Foreground="{DynamicResource TextMutedColor}" VerticalAlignment="Top" Margin="0,1,0,0"/>
                <TextBlock Text="{Binding Localization[UtilitiesDisclaimer]}" Classes="muted" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>