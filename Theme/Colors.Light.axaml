<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="TextColor"              Color="#111318"/>
    <SolidColorBrush x:Key="TextMutedColor"         Color="#555C6E"/>
    <SolidColorBrush x:Key="BgColor"                Color="#F3F4F6"/>
    <SolidColorBrush x:Key="BorderColor"            Color="#C8CDD8"/>
    <SolidColorBrush x:Key="BorderColorTransparent" Color="#00C8CDD8"/>
    <!-- AccentColor (#F97316) at 15% alpha (#26), pre-blended opaque over this theme's BgColor
         (#F3F4F6): result = alpha*fg + (1-alpha)*bg per channel, alpha = 0x26/255 = 0.14902.
         R: 0.14902*249 + 0.85098*243 = 243.89 -> 0xF4
         G: 0.14902*115 + 0.85098*244 = 224.78 -> 0xE1
         B: 0.14902*22  + 0.85098*246 = 212.62 -> 0xD5
         See Colors.Dark.axaml for why this needs to stay opaque instead of just reusing the
         translucent value directly. -->
    <SolidColorBrush x:Key="AccentSurfaceColor"     Color="#F4E1D5"/>
</ResourceDictionary>