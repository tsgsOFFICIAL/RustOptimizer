<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iface="using:RustOptimizer.Interface"
        xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
        xmlns:controls="using:RustOptimizer.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RustOptimizer.MainWindow"
        x:DataType="iface:ILocalizationService"
        Title="{Binding [AppTitle]}"
        Icon="/Assets/App/logo.ico"
        Width="480" Height="360"
        MinWidth="400" MinHeight="300"
        Background="{DynamicResource BgColor}"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*">

        <controls:TitleBar Grid.Row="0" Title="{Binding [AppTitle]}" Author="tsgsOFFICIAL">
            <controls:TitleBar.Icon>
                <Image Source="/Assets/App/logo.ico"/>
            </controls:TitleBar.Icon>
        </controls:TitleBar>

        <StackPanel Grid.Row="1" Margin="24" Spacing="12">

            <StackPanel Orientation="Horizontal" Spacing="8">
                <iconPacks:PackIconSimpleIcons Kind="Discord"
                                               Width="32"
                                               Height="32"
                                               Foreground="#5865F2"/>
                <TextBlock Text="{Binding [Hello]}" Classes="title" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="EN" Click="OnEnglish"/>
                <Button Content="DK" Click="OnDanish"/>
                <Button Content="RU" Click="OnRussian"/>
            </StackPanel>

            <TextBlock Text="{Binding [Subtitle]}" Classes="muted"/>

            <Border Classes="card">
                <TextBlock Text="{Binding [CardContent]}"
                           Foreground="{DynamicResource TextColor}"/>
            </Border>

            <Button Content="{Binding [AccentButton]}" Classes="accent"/>
            <Button Content="{Binding [ToggleTheme]}" Click="OnThemeToggle"/>

        </StackPanel>

    </Grid>

</Window>